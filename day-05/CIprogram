import java.util.*;
public class basics1 {
    public static void main(String[] args) {
        Scanner sc= new Scanner(System.in);
        double principal;
        double rate;
        int time;
        double nooftimescompounded;;
        double amount;
        System.out.print("Enter the principal amount: ");
        principal = sc.nextDouble();    
        System.out.print("Enter the annual interest rate (in %): ");
        rate = sc.nextDouble();
        rate = rate / 100; // Convert percentage to decimal
        System.out.print("Enter the time in years: ");
        time = sc.nextInt();
        System.out.print("Enter the number of times interest is compounded per year: ");
        nooftimescompounded = sc.nextDouble();
        amount = principal * Math.pow(1 + rate / nooftimescompounded, nooftimescompounded * time);
        System.out.printf("The amount after %d years is: rupees %.2f", time, amount);
        double ci = amount - principal;
        System.out.printf("\nThe compound interest earned is: rupees %.2f", ci);    
    }
}
